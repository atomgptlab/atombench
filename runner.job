#!/bin/bash

#SBATCH --job-name=runner
#SBATCH --partition=nvl
#SBATCH --time=23:59:59
#SBATCH --mem=64G

source ~/.bashrc
module load cuda/11.5.0
eval "$(conda shell.bash hook)"
conda env list
conda activate atombench

snakemake -p --verbose --show-failed-logs --rerun-triggers mtime --forcerun compile_results --cores 1
