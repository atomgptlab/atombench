#!/bin/bash
#SBATCH --job-name=mgen_base_alex
#SBATCH --gres=gpu:1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=8
#SBATCH --output=slurm_alex_mattergen_base_infer.out


eval "$(conda shell.bash hook)"
source scripts/absolute_path.sh
module load cuda/11.8
conda activate mattergen

ROOT="${ABS_PATH%/}"
RESULTS_PATH="${ROOT}/job_runs/mattergen_base_benchmark_alex/results"
TEST_CSV="${ROOT}/models/cdvae/data/alexandria/test.csv"

if [[ ! -f "${TEST_CSV}" ]]; then
  echo "ERROR: test CSV not found at ${TEST_CSV}"
  exit 1
fi

NUM_STRUCTURES=$(python -c "import pandas as pd; print(len(pd.read_csv('${TEST_CSV}')))")
BATCH_SIZE=16
NUM_BATCHES=$(python -c "import math; print(math.ceil(${NUM_STRUCTURES} / ${BATCH_SIZE}))")

echo "Test set size: ${NUM_STRUCTURES}, generating ${NUM_BATCHES} batches of ${BATCH_SIZE}"

mkdir -p "${RESULTS_PATH}"

SECONDS=0
start_iso="$(date -Iseconds)"

nvidia-smi

python - <<'PYEOF'
import sys
from huggingface_hub import hf_hub_download
REPO = "microsoft/mattergen"
FILES = [
    "checkpoints/mattergen_base/checkpoints/last.ckpt",
    "checkpoints/mattergen_base/config.yaml",
]
missing = []
for f in FILES:
    try:
        hf_hub_download(REPO, f, local_files_only=True)
    except Exception:
        missing.append(f)
if missing:
    print("ERROR: mattergen_base checkpoint not in local HuggingFace cache.", file=sys.stderr)
    print("Missing files:", file=sys.stderr)
    for f in missing:
        print(f"  {f}", file=sys.stderr)
    print("Re-run the environment setup job (conda_env.job) to download them.", file=sys.stderr)
    sys.exit(1)
print("[✓] mattergen_base checkpoint verified in local cache")
PYEOF

mattergen-generate "${RESULTS_PATH}" \
    --pretrained_name=mattergen_base \
    --batch_size=${BATCH_SIZE} \
    --num_batches=${NUM_BATCHES} \
    --record-trajectories=False

echo "Done"

elapsed="$SECONDS"
end_iso="$(date -Iseconds)"

printf "Start: %s\nEnd:   %s\nElapsed: %ds (%.2f min, %.2f hr)\n" \
  "$start_iso" "$end_iso" "$elapsed" \
  "$(awk "BEGIN{print $elapsed/60}")" \
  "$(awk "BEGIN{print $elapsed/3600}")"
