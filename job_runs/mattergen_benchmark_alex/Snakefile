rule train_mattergen_alex:
    output:
        touch("mattergen_benchmark_alex.trained")
    input:
        "mattergen_env.created",
        "alex_data.created"
    shell:
        """
        sbatch --wait -p nvl --time=24:00:00 job_runs/mattergen_benchmark_alex/train_mattergen.job
        """

rule infer_mattergen_alex:
    output:
        touch("mattergen_benchmark_alex.inferred")
    input:
        "mattergen_env.created",
        "alex_data.created",
        "mattergen_benchmark_alex.trained"
    shell:
        """
        sbatch --wait -p nvl --time=04:00:00 job_runs/mattergen_benchmark_alex/inference_mattergen.job
        """

rule benchmark_mattergen_alex:
    output:
        touch("mattergen_benchmark_alex.final")
    input:
        "mattergen_env.created",
        "alex_data.created",
        "mattergen_benchmark_alex.trained",
        "mattergen_benchmark_alex.inferred"
    shell:
        """
        eval "$(conda shell.bash hook)"
        conda activate mattergen
        source scripts/absolute_path.sh
        ROOT="${{ABS_PATH%/}}"
        python job_runs/mattergen_benchmark_alex/write_benchmark.py \
            --results_path  job_runs/mattergen_benchmark_alex/results \
            --test_csv      "${{ROOT}}/models/cdvae/data/alexandria/test.csv" \
            --output_csv    job_runs/mattergen_benchmark_alex/AI-AtomGen-prop-dft_3d-test-rmse.csv
        """
