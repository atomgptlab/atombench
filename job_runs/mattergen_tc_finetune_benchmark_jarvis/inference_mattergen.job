#!/bin/bash
#SBATCH --job-name=mgen_tc_jrv
#SBATCH --gres=gpu:1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=8
#SBATCH --output=slurm_jarvis_mattergen_tc_finetune_infer.out


eval "$(conda shell.bash hook)"
source scripts/absolute_path.sh
module load cuda/11.8
conda activate mattergen

ROOT="${ABS_PATH%/}"
MATTERGEN_RUN_ROOT="${ROOT}/job_runs/mattergen_tc_finetune_benchmark_jarvis/outputs"
RESULTS_PATH="${ROOT}/job_runs/mattergen_tc_finetune_benchmark_jarvis/results"
TEST_CSV="${ROOT}/models/cdvae/data/supercon/test.csv"

if [[ ! -f "${TEST_CSV}" ]]; then
  echo "ERROR: test CSV not found at ${TEST_CSV}"
  exit 1
fi

mkdir -p "${RESULTS_PATH}"

SECONDS=0
start_iso="$(date -Iseconds)"

nvidia-smi

python job_runs/mattergen_tc_finetune_benchmark_jarvis/run_tc_inference.py \
    --model_path   "${MATTERGEN_RUN_ROOT}" \
    --test_csv     "${TEST_CSV}" \
    --tc_column    "Tc_supercon" \
    --output_path  "${RESULTS_PATH}" \
    --guidance_factor 2.0

echo "Done"

elapsed="$SECONDS"
end_iso="$(date -Iseconds)"

printf "Start: %s\nEnd:   %s\nElapsed: %ds (%.2f min, %.2f hr)\n" \
  "$start_iso" "$end_iso" "$elapsed" \
  "$(awk "BEGIN{print $elapsed/60}")" \
  "$(awk "BEGIN{print $elapsed/3600}")"
