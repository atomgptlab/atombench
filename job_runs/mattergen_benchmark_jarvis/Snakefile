rule train_mattergen_jarvis:
    output:
        touch("mattergen_benchmark_jarvis.trained")
    input:
        "mattergen_env.created",
        "jarvis_data.created"
    shell:
        """
        sbatch --wait -p nvl --time=08:00:00 job_runs/mattergen_benchmark_jarvis/train_mattergen.job
        """

rule infer_mattergen_jarvis:
    output:
        touch("mattergen_benchmark_jarvis.inferred")
    input:
        "mattergen_env.created",
        "jarvis_data.created",
        "mattergen_benchmark_jarvis.trained"
    shell:
        """
        sbatch --wait -p nvl --time=04:00:00 job_runs/mattergen_benchmark_jarvis/inference_mattergen.job
        """

rule benchmark_mattergen_jarvis:
    output:
        touch("mattergen_benchmark_jarvis.final")
    input:
        "mattergen_env.created",
        "jarvis_data.created",
        "mattergen_benchmark_jarvis.trained",
        "mattergen_benchmark_jarvis.inferred"
    shell:
        """
        eval "$(conda shell.bash hook)"
        conda activate mattergen
        source scripts/absolute_path.sh
        ROOT="${{ABS_PATH%/}}"
        python job_runs/mattergen_benchmark_jarvis/write_benchmark.py \
            --results_path  job_runs/mattergen_benchmark_jarvis/results \
            --test_csv      "${{ROOT}}/models/cdvae/data/supercon/test.csv" \
            --output_csv    job_runs/mattergen_benchmark_jarvis/AI-AtomGen-prop-dft_3d-test-rmse.csv
        """
